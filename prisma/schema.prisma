generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String?
  username              String?   @unique
  password_hash         String?
  image                 String?
  is_active             Boolean   @default(true)
  subscription_tier     String    @default("free")
  default_risk_tolerance String   @default("medium")
  last_login            DateTime?
  email_verified        DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  subscription          UserSubscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   @unique
  name_ar         String
  price           Float
  price_yearly    Float?
  trial_days      Int      @default(0)
  features        String
  max_watchlist   Int      @default(5)
  max_portfolio   Int      @default(3)
  max_alerts      Int      @default(10)
  ai_analysis     Boolean  @default(false)
  deep_analysis   Boolean  @default(false)
  priority_support Boolean @default(false)
  is_active       Boolean  @default(true)
  sort_order      Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  users UserSubscription[]
}

model UserSubscription {
  id               String    @id @default(cuid())
  user_id          String
  plan_id          String
  status           String    @default("active")
  started_at       DateTime  @default(now())
  expires_at       DateTime?
  trial_started_at DateTime?
  trial_ends_at    DateTime?
  auto_renew       Boolean   @default(false)
  payment_method   String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  user User            @relation(fields: [user_id], references: [id])
  plan SubscriptionPlan @relation(fields: [plan_id], references: [id])

  @@unique([user_id])
}

// ==================== PORTFOLIO ====================

model PortfolioPosition {
  id                String   @id @default(cuid())
  user_id           String
  stock_symbol      String
  shares            Float
  avg_cost          Float
  entry_date        DateTime @default(now())
  
  // Current state (updated on each refresh)
  current_price     Float?
  market_value      Float?
  cost_basis        Float?
  unrealized_pnl    Float?
  unrealized_pnl_percent Float?
  
  // Analysis fields (computed)
  fair_value        Float?
  upside_potential  Float?   // % to fair value
  trailing_stop     Float?
  trailing_stop_percent Float? @default(5.0)
  highest_price_since_entry Float?
  
  // Recommendation
  recommendation    String?  // HOLD, ADD, REDUCE, SELL
  confidence        Float?   // 0-100
  reasoning         String?  // Arabic explanation
  
  // Average down tracking
  avg_down_count    Int      @default(0)
  total_invested    Float?
  
  // Metadata
  notes             String?
  is_active         Boolean  @default(true)
  last_analyzed     DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@unique([user_id, stock_symbol])
  @@index([user_id])
  @@index([stock_symbol])
}

model PortfolioTransaction {
  id              String   @id @default(cuid())
  position_id     String
  type            String   // BUY, SELL, DIVIDEND
  shares          Float
  price           Float
  total           Float
  transaction_date DateTime @default(now())
  notes           String?
  created_at      DateTime @default(now())

  @@index([position_id])
}
